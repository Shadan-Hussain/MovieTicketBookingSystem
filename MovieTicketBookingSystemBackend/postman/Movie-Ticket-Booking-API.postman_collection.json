{
	"info": {
		"_postman_id": "movie-ticket-booking-api",
		"name": "Movie Ticket Booking API",
		"description": "API requests for the Movie Ticket Booking backend. Set {{baseUrl}} (e.g. http://localhost:8080). After **Login**, the token is saved to {{token}} for authenticated requests.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{ "key": "baseUrl", "value": "http://localhost:8081" },
		{ "key": "token", "value": "" }
	],
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Signup",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"testuser\",\n  \"password\": \"password123\",\n  \"email\": \"testuser@example.com\",\n  \"name\": \"Test User\"\n}"
						},
						"url": "{{baseUrl}}/auth/signup",
						"description": "Creates a new user. Returns only id; use Login to get a token."
					}
				},
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    try {",
									"        const json = pm.response.json();",
									"        const token = json.token;",
									"        if (token) {",
									"            pm.collectionVariables.set('token', token);",
									"            if (typeof pm.environment !== 'undefined') {",
									"                pm.environment.set('token', token);",
									"            }",
									"        }",
									"    } catch (e) {",
									"        console.log('Could not save token:', e);",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"testuser\",\n  \"password\": \"password123\"\n}"
						},
						"url": "{{baseUrl}}/auth/login",
						"description": "Returns token and userId. Token is saved to collection variable for other requests."
					}
				}
			]
		},
		{
			"name": "Admin (JWT with ADMIN role required)",
			"item": [
				{
					"name": "Get Theatre Options",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": "{{baseUrl}}/admin/options/theatres",
						"description": "Returns dropdown options (id, label) for theatres. Use when adding halls."
					}
				},
				{
					"name": "Get Hall Options",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": "{{baseUrl}}/admin/options/halls",
						"description": "Returns dropdown options (id, label) for halls. Use when adding shows."
					}
				},
				{
					"name": "Get Movie Options",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": "{{baseUrl}}/admin/options/movies",
						"description": "Returns dropdown options (id, label, durationMins) for movies. Use when adding shows."
					}
				},
				{
					"name": "Add City",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Mumbai\"\n}"
						},
						"url": "{{baseUrl}}/admin/cities",
						"description": "Requires user with role ADMIN. Log in as admin (e.g. shadan) first. Returns created city id."
					}
				},
				{
					"name": "Add Theatre",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"cityId\": 1,\n  \"name\": \"PVR Andheri\",\n  \"address\": \"Andheri West, Mumbai\"\n}"
						},
						"url": "{{baseUrl}}/admin/theatres",
						"description": "Replace cityId with a valid city id. Returns theatre id."
					}
				},
				{
					"name": "Add Hall (with seats)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"theatreId\": 1,\n  \"name\": \"Screen 1\",\n  \"rows\": 5,\n  \"cols\": 6,\n  \"premiumRowEnd\": 2,\n  \"priceNormal\": 100,\n  \"pricePremium\": 200\n}"
						},
						"url": "{{baseUrl}}/admin/halls",
						"description": "Single request: creates hall and seat grid. All fields required. theatreId, name, rows, cols, premiumRowEnd (1-based; 0 = no premium), priceNormal, pricePremium. Returns hall id."
					}
				},
				{
					"name": "Add Movie",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"body": {
							"mode": "formdata",
							"formdata": [
								{ "key": "movie", "type": "text", "value": "{\"name\":\"Inception\",\"durationMins\":148,\"description\":\"A mind-bending thriller.\",\"language\":\"EN\"}", "description": "JSON: name, durationMins, description, language. Part must be Content-Type application/json." },
								{ "key": "file", "type": "file", "src": [], "description": "Optional poster image (JPEG/PNG/WebP, max 2 MB)" }
							]
						},
						"url": "{{baseUrl}}/admin/movies",
						"description": "Multipart: part 'movie' (JSON with name, durationMins, description, language); optional part 'file' (poster). Returns movie id."
					}
				},
				{
					"name": "Delete Hall",
					"request": {
						"method": "DELETE",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": "{{baseUrl}}/admin/halls/1",
						"description": "Replace 1 with hall id. Deletes hall and all its seats, shows, and show_seats. Fails if hall has transactions (e.g. paid tickets)."
					}
				},
				{
					"name": "Add Show",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"movieId\": 1,\n  \"hallId\": 1,\n  \"startTime\": \"2025-03-15T18:00:00+05:30\",\n  \"endTime\": \"2025-03-15T20:30:00+05:30\"\n}"
						},
						"url": "{{baseUrl}}/admin/shows",
						"description": "Replace movieId/hallId. Use ISO-8601 for startTime/endTime. Start time must be in the future (400 otherwise). Times must not overlap other shows in same hall. Returns show id."
					}
				}
			]
		},
		{
			"name": "User (JWT required)",
			"item": [
				{
					"name": "List Cities",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": "{{baseUrl}}/cities",
						"description": "Requires valid JWT. Run Login first to set {{token}}."
					}
				},
				{
					"name": "Get Movies by City",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": {
							"raw": "{{baseUrl}}/movies?city_id=1",
							"host": ["{{baseUrl}}"],
							"path": ["movies"],
							"query": [
								{ "key": "city_id", "value": "1", "description": "City id" }
							]
						},
						"description": "Movies that have shows in the given city."
					}
				},
				{
					"name": "Get Movie",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": "{{baseUrl}}/movies/1",
						"description": "Replace 1 with movie id. Returns single movie (name, durationMins, description, hasPoster, language)."
					}
				},
				{
					"name": "Get Movie Poster",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": "{{baseUrl}}/movies/1/poster",
						"description": "Replace 1 with movie id. Requires JWT. Returns poster image bytes. 404 if movie has no stored poster."
					}
				},
				{
					"name": "Get Shows",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": {
							"raw": "{{baseUrl}}/shows?city_id=1&movie_id=1",
							"host": ["{{baseUrl}}"],
							"path": ["shows"],
							"query": [
								{ "key": "city_id", "value": "1" },
								{ "key": "movie_id", "value": "1" }
							]
						},
						"description": "Shows for the given city and movie. Only returns shows whose start time is in the future."
					}
				},
				{
					"name": "Get Show by ID",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": "{{baseUrl}}/shows/1",
						"description": "Replace 1 with show id. Returns show details (showId, movieName, theatreName, hallName, startTime, endTime) for the seat map page. 400 'Show ended or already started' if show has already started or ended. 404 if show not found."
					}
				},
				{
					"name": "Get Seats for Show",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": "{{baseUrl}}/shows/1/seats",
						"description": "Replace 1 with show id. Returns seats with status (AVAILABLE/LOCKED/BOOKED) from DB and Redis. 400 'Show ended or already started' if show has already started or ended."
					}
				},
				{
					"name": "Lock Seat",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": "{{baseUrl}}/shows/1/seats/1/lock",
						"description": "Replace 1/1 with showId/seatId. Lock is tied to the authenticated user. Returns 'Seat successfully locked' or 409 with 'Seat not available at the moment' if seat is locked."
					}
				},
				{
					"name": "Create Payment Session",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": "{{baseUrl}}/shows/1/seats/1/payment-session",
						"description": "Replace with showId/seatId. Only works if the seat is locked by the same user. Returns Stripe checkout session URL."
					}
				},
				{
					"name": "Get My Tickets (list)",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": "{{baseUrl}}/tickets",
						"description": "Returns all tickets for the authenticated user (no query params). Each ticket includes ticketId, showId, seatId/seatNumber, movieName, theatreName, theatreAddress, hallName, showStartTime, showEndTime and transactionId."
					}
				},
				{
					"name": "Get Ticket",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": {
							"raw": "{{baseUrl}}/tickets?show_id=1&seat_id=1",
							"host": ["{{baseUrl}}"],
							"path": ["tickets"],
							"query": [
								{ "key": "show_id", "value": "1" },
								{ "key": "seat_id", "value": "1" }
							]
						},
						"description": "Returns single ticket (ticketId, showId, seatId/seatNumber, movieName, theatreName, theatreAddress, hallName, showStartTime, showEndTime, transactionId) if the user has a successful payment for this show+seat. 400 'payment failed' if the user's latest transaction for this show+seat is FAILED. 400 'Ticket creation failed, refund initiated' if transaction is REFUND_INITIATED. 404 if no ticket or transaction for this user."
					}
				},
				{
					"name": "Get My Transactions",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": "{{baseUrl}}/transactions",
						"description": "Returns list of current user's transactions (PENDING excluded)."
					}
				}
			]
		},
		{
			"name": "Redirect (payment callback)",
			"item": [
				{
					"name": "Payment Success",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/redirect/success?session_id=cs_test_xxx",
							"host": ["{{baseUrl}}"],
							"path": ["redirect", "success"],
							"query": [
								{ "key": "session_id", "value": "cs_test_xxx" }
							]
						},
						"description": "Stripe redirects here after successful payment. session_id from Stripe."
					}
				},
				{
					"name": "Payment Cancel",
					"request": {
						"method": "GET",
						"url": "{{baseUrl}}/redirect/cancel",
						"description": "Stripe redirects here when user cancels checkout."
					}
				}
			]
		},
		{
			"name": "Webhook (Stripe)",
			"item": [
				{
					"name": "Stripe Webhook",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Stripe-Signature", "value": "t=123,v1=xxx", "description": "Stripe signs the payload; use stripe listen for local testing" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\"type\":\"checkout.session.completed\"}"
						},
						"url": "{{baseUrl}}/webhook/stripe",
						"description": "Called by Stripe (e.g. checkout.session.completed). For local testing use: stripe listen --forward-to localhost:8081/webhook/stripe. Signature is required."
					}
				}
			]
		}
	]
}
